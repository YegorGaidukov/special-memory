# Base URL under which the explorer fetches memory assets (splat .ply + thumbnail).
# This is the ONLY place that knows where splats live, so storage can move
# (dev public/ folder today, a static host / CDN for the exhibition) without
# touching code. Relative paths in manifest.json are resolved against this.
#
# Dev default: the app's own public/memories/ folder, served statically.
# Copy this file to `.env.local` to override.
NEXT_PUBLIC_MEMORIES_BASE_URL=/memories
