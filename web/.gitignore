# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# seed memory assets: large/binary splats + thumbnails stay local.
# manifest.json and README.md ARE tracked (small, hand-authored source).
/public/memories/*.ply
/public/memories/*.ksplat
/public/memories/*.jpg
/public/memories/*.jpeg
/public/memories/*.png

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
